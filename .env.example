# Telegram bot token from BotFather
token=1234123412:ABCDEFABCDEFABCDEFABCDEFABCDEFABCDE

# Production runtime database URL (external Postgres for docker-compose.yml)
ps_url=postgresql+psycopg://user:password@host:5432/db

# Test database URL (used by pytest in docker-compose.test.yml)
testps_url=postgresql+psycopg://postgres:postgres@db:5432/postgres
